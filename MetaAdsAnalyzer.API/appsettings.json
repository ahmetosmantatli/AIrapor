{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=MetaAdsAnalyzer;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Meta": {
    "AppId": "YOUR_META_APP_ID",
    "AppSecret": "YOUR_META_APP_SECRET",
    "RedirectUri": "http://localhost:5195/api/auth/meta/callback",
    "PostLoginRedirectUri": "http://localhost:5173/",
    "ApiVersion": "v19.0",
    "Scopes": "email,public_profile,ads_read"
  },
  "MetaInsightsScheduling": {
    "Enabled": false,
    "TickSeconds": 60,
    "TodayIntervalHours": 4,
    "YesterdayRunUtcHour": 8,
    "SummaryRunUtcHour": 3,
    "Levels": [ "campaign", "adset", "ad" ],
    "SummaryDatePresets": [ "last_7d", "last_14d", "last_30d" ],
    "DelayMsBetweenSyncCalls": 600,
    "TodayDatePreset": "today",
    "YesterdayDatePreset": "yesterday"
  },
  "Admin": {
    "PlansApiKey": ""
  },
  "Jwt": {
    "SecretKey": "DEV_ONLY_CHANGE_IN_PRODUCTION_MIN_32_CHARS!!",
    "Issuer": "MetaAdsAnalyzer",
    "Audience": "MetaAdsAnalyzer",
    "ExpiresMinutes": 10080
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
